# Copy this file to `.env` for local development.
# This project reads `.env` directly, not `.env.local`.

POSTGRES_URL=postgresql://***
# Must be a real http(s) URL (origin with hostname). Not an API key or opaque token — those break React Router SSR and ScreenshotOne.
BASE_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
AUTH_SECRET=***

# Origin where AI-generated landing pages render (iframe + ScreenshotOne + published share links).
# MUST be a different host from the main app — the cross-origin iframe is what isolates AI-generated
# JS from your cookies, storage, and APIs.
# Local dev: http://deploy.localhost:3000 (browsers treat this as a separate origin from localhost).
# Production: https://sunset-deploy.com
NEXT_PUBLIC_DEPLOY_ORIGIN=http://deploy.localhost:3000

# AI
AI_MODEL_PROVIDER=anthropic
AI_MODEL_NAME=claude-sonnet-4-6
# Still used for lightweight tasks like chat title generation.
AI_LIGHTER_MODEL_NAME=claude-haiku-4.5
AI_USE_GATEWAY=true
AI_GATEWAY_API_KEY=vck_***
# Anthropic only: split stable instructions for prompt caching (ephemeral). Set to false to disable.
# CODEGEN_PROMPT_CACHE=false
# CHAT_PROMPT_CACHE=false
# Optional if you disable AI gateway:
# ANTHROPIC_API_KEY=sk-ant-***
# OPENAI_API_KEY=sk-proj-***
# GOOGLE_GENERATIVE_AI_API_KEY=AIza***
# Inspiration library (admin + create_section inspirationQuery) uses OpenAI text-embedding-3-small and needs OPENAI_API_KEY even when chat runs on another provider.

# Google auth
GOOGLE_CLIENT_ID=***
GOOGLE_CLIENT_SECRET=***

# Billing
STRIPE_SECRET_KEY=sk_test_***
STRIPE_WEBHOOK_SECRET=whsec_***
STRIPE_STARTER_PRICE_ID=price_***
STRIPE_TOPUP_100_PRICE_ID=price_***

# Assets and observability
SCREENSHOTONE_ACCESS_KEY=***
# Public https origin ScreenshotOne can reach (no path). Local dev: run `ngrok http 3000` (or Cloudflare Tunnel) and paste the forwarding URL, e.g. https://abc123.ngrok-free.app — localhost is skipped automatically.
# The app sends `ngrok-skip-browser-warning` on ScreenshotOne navigations so the free ngrok interstitial does not block headless capture.
SCREENSHOT_BROWSER_BASE_URL=https://***
# If unset, server tries APP_BASE_URL, BASE_URL, NEXT_PUBLIC_APP_URL, VERCEL_URL (loopback hosts are ignored for screenshots).
# Optional separate secret for render-snapshot JWTs; defaults to AUTH_SECRET.
# RENDER_SNAPSHOT_SECRET=***
# Optional ms to wait after first React paint before ScreenshotOne fires (Motion / fonts). Default 3800.
# LANDING_SNAPSHOT_POST_PAINT_MS=5500
# Optional extra ScreenshotOne navigation headers (`Name:Value` per line or comma-separated).
# SCREENSHOTONE_NAVIGATION_HEADERS=X-Custom:yes
BLOB_READ_WRITE_TOKEN=***
# LangSmith (Vercel AI SDK tracing via `wrapAISDK` in lib/ai/langsmith-ai.ts)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_***
# Must match the region of the org (browser). EU example:
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
# US default:   https://api.smith.langchain.com
# LANGSMITH_PROJECT=default

# Support / error reporting
SUPPORT_EMAIL=support@example.com
RESEND_API_KEY=re_***
SUPPORT_EMAIL_FROM=Sunset <onboarding@resend.dev>
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# Trigger / internal jobs
TRIGGER_SECRET_KEY=tr_dev_***
INTERNAL_JOB_SECRET=***
ENABLE_TRIGGER_CHAT_QUEUE=1

# Stream bus (Upstash / Vercel KV REST)
STORAGE_KV_REST_API_URL=https://***.upstash.io
STORAGE_KV_REST_API_TOKEN=***
ENABLE_REDIS_STREAM_BUS=1
STREAM_BUS_DB_FALLBACK=1
REDIS_STREAM_READ_TIMEOUT_MS=1500
REDIS_STREAM_WRITE_TIMEOUT_MS=7000
REDIS_STREAM_COOLDOWN_MS=20000

# Optional
# CRON_SECRET=
NEXT_PUBLIC_GA_ID=G-LS8GGEJ28D

# i18n
# Set to "1" once the Polish legal pages (privacy, terms) have been reviewed by a lawyer.
# When unset/0, those pages display a draft-translation banner directing readers to the English version.
# LEGAL_PL_REVIEWED=1
