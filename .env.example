# This is an example of your .env file format, which pnpm db:setup will create.
# Note: this must be .env, not .env.local, without further configuration changes.
POSTGRES_URL=postgresql://***
STRIPE_SECRET_KEY=sk_test_***
STRIPE_WEBHOOK_SECRET=whsec_***
STRIPE_STARTER_PRICE_ID=price_***
# One-time payment for 100 credits top-up (69 PLN). Create a Product + one-time Price in Stripe.
STRIPE_TOPUP_100_PRICE_ID=price_*** 
BASE_URL=http://localhost:3000
AUTH_SECRET=***

GOOGLE_CLIENT_ID=***
GOOGLE_CLIENT_SECRET=***

# Screenshot capture for landing page sneak peeks (start page)
# Get your key at https://dash.screenshotone.com/access
SCREENSHOTONE_ACCESS_KEY=***

# Langfuse for LLM observability (https://cloud.langfuse.com or self-hosted)
LANGFUSE_SECRET_KEY=sk-lf-***
LANGFUSE_PUBLIC_KEY=pk-lf-***
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# AI model (switch provider: google | openai | anthropic)
AI_MODEL_PROVIDER=anthropic
AI_MODEL_NAME=claude-sonnet-4-6
AI_LIGHTER_MODEL_NAME=claude-3-5-haiku-20241022
# Resumable stream bus (Upstash Redis on Vercel)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Enable Redis stream bus for chat event streaming.
ENABLE_REDIS_STREAM_BUS=0
# Keep Postgres mirroring/fallback enabled unless explicitly disabled.
STREAM_BUS_DB_FALLBACK=1
# Optional tuning
# Read timeout should stay relatively low for SSE responsiveness.
REDIS_STREAM_READ_TIMEOUT_MS=1500
# Publish timeout can be higher because batches may include multiple events.
REDIS_STREAM_WRITE_TIMEOUT_MS=7000
# Cooldown after Redis failure before retrying Redis path.
REDIS_STREAM_COOLDOWN_MS=20000
# For Google: get key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=***
# For OpenAI: OPENAI_API_KEY=***

# Vercel Blob for storing screenshots (auto-configured on Vercel)
# For local dev: create a Blob store at vercel.com and run s`vercel env pull`
BLOB_READ_WRITE_TOKEN=***

# Optional: secret for cron endpoints (e.g. GET /api/cron/rollover). Set Authorization: Bearer <value>
# CRON_SECRET=

# In-app "Report error" (chat): emails go to SUPPORT_EMAIL via Resend.
# https://resend.com — create API key; for testing, from can be "Sunset <onboarding@resend.dev>"
SUPPORT_EMAIL=skupantoni920@gmail.com
RESEND_API_KEY=re_PpJ5nQXh_KnSicYUchgNJ3LjMDor3oBdM
SUPPORT_EMAIL_FROM=Sunset <onboarding@resend.dev>
# If Resend is not set, the app opens the user's mail client; use same address as SUPPORT_EMAIL.
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com